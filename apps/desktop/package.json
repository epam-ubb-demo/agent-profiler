{
  "name": "@agent-profiler/desktop",
  "version": "0.0.0",
  "private": true,
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run --passWithNoTests",
    "regression": "vitest run __tests__/regression/",
    "test:e2e": "playwright test",
    "pack": "electron-builder --dir --config electron-builder.config.ts",
    "dist": "electron-builder --config electron-builder.config.ts",
    "dist:mac": "electron-builder --mac --config electron-builder.config.ts",
    "dist:win": "electron-builder --win --config electron-builder.config.ts",
    "dist:linux": "electron-builder --linux --config electron-builder.config.ts"
  },
  "dependencies": {
    "@agent-profiler/core": "workspace:*",
    "@agent-profiler/data-source": "workspace:*",
    "@agent-profiler/ui": "workspace:*",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-slot": "^1.1.1",
    "@tanstack/react-query": "^5.62.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.469.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@agent-profiler/adapters-copilot-cli": "workspace:*",
    "@agent-profiler/adapters-ctb": "workspace:*",
    "@agent-profiler/adapters-vscode-chat": "workspace:*",
    "@agent-profiler/annotations": "workspace:*",
    "@agent-profiler/plugins": "workspace:*",
    "@agent-profiler/pricing": "workspace:*",
    "@agent-profiler/tsconfig-base": "workspace:*",
    "@playwright/test": "^1.49.0",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^33.3.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "jsdom": "^25.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
