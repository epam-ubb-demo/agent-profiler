{
  "name": "@agent-profiler/desktop",
  "version": "0.0.0",
  "private": true,
  "description": "Agent Profiler desktop application for visualising AI agent session logs",
  "author": {
    "name": "EPAM Systems",
    "email": "agent-profiler@epam.com"
  },
  "homepage": "https://github.com/epam-ubb-demo/agent-profiler",
  "repository": {
    "type": "git",
    "url": "https://github.com/epam-ubb-demo/agent-profiler.git"
  },
  "license": "Apache-2.0",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run --passWithNoTests",
    "regression": "vitest run __tests__/regression/",
    "test:e2e": "playwright test",
    "pack": "electron-builder --dir --config electron-builder.config.ts",
    "dist": "electron-builder --config electron-builder.config.ts --publish never",
    "dist:mac": "electron-builder --mac --config electron-builder.config.ts --publish never",
    "dist:win": "electron-builder --win --config electron-builder.config.ts --publish never",
    "dist:linux": "electron-builder --linux --config electron-builder.config.ts --publish never"
  },
  "dependencies": {
    "@agent-profiler/adapters-application-insights": "workspace:*",
    "@agent-profiler/core": "workspace:*",
    "@agent-profiler/data-source": "workspace:*",
    "@agent-profiler/export-pdf": "workspace:*",
    "@agent-profiler/ui": "workspace:*",
    "@azure/identity": "^4.6.0",
    "@epam/assets": "^6.4.4",
    "@epam/loveship": "^6.4.4",
    "@epam/uui": "^6.4.4",
    "@epam/uui-components": "^6.4.4",
    "@epam/uui-core": "^6.4.4",
    "@tanstack/react-query": "^5.62.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-store": "^10.0.0",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.469.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@agent-profiler/adapters-copilot-cli": "workspace:*",
    "@agent-profiler/adapters-ctb": "workspace:*",
    "@agent-profiler/adapters-vscode-chat": "workspace:*",
    "@agent-profiler/annotations": "workspace:*",
    "@agent-profiler/plugins": "workspace:*",
    "@agent-profiler/pricing": "workspace:*",
    "@agent-profiler/tsconfig-base": "workspace:*",
    "@playwright/test": "^1.49.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^33.3.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "jsdom": "^25.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
