---
/**
 * Custom footer component for the Agent Profiler documentation.
 * Displays MIT licence notice and repository link.
 */
---

<footer class="site-footer">
  <p>
    Released under the <a href="https://github.com/epam-ubb-demo/agent-profiler/blob/main/LICENSE">MIT Licence</a>.
    <span class="separator">·</span>
    <a href="https://github.com/epam-ubb-demo/agent-profiler">GitHub</a>
  </p>
</footer>

<style>
  .site-footer {
    padding: 1.5rem;
    text-align: center;
    font-size: 0.875rem;
    color: var(--sl-color-gray-3);
    border-top: 1px solid var(--sl-color-gray-6);
  }

  .site-footer a {
    color: var(--sl-color-white);
    text-decoration: underline;
  }

  .separator {
    margin: 0 0.5rem;
  }
</style>
