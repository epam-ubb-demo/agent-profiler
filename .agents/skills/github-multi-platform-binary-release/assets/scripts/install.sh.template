#!/usr/bin/env sh
# {{BINARY_NAME}} installer for Linux and macOS.
#
# Usage:
#   curl -fsSL https://raw.githubusercontent.com/{{REPO}}/main/install.sh | sh
#   curl -fsSL .../install.sh | VERSION=v1.2.3 sh
#   curl -fsSL .../install.sh | INSTALL_DIR=$HOME/bin sh
#
# Environment variables:
#   VERSION       Release tag to install (default: latest stable release)
#   INSTALL_DIR   Target directory (default: {{DEFAULT_INSTALL_DIR}})
#   REPO          owner/repo (default: {{REPO}})
#   GITHUB_URL    GitHub API base (default: https://api.github.com)

set -eu

BINARY_NAME="{{BINARY_NAME}}"
REPO="${REPO:-{{REPO}}}"
INSTALL_DIR="${INSTALL_DIR:-{{DEFAULT_INSTALL_DIR}}}"
GITHUB_URL="${GITHUB_URL:-https://api.github.com}"
VERSION="${VERSION:-}"

log()  { printf '%s\n' "$*" >&2; }
fail() { log "error: $*"; exit 1; }

# ---------------------------------------------------------------------------
# Detect OS / arch and map to the asset naming convention used by the
# build-release workflow.
# ---------------------------------------------------------------------------
detect_platform() {
  uname_s=$(uname -s 2>/dev/null || echo unknown)
  uname_m=$(uname -m 2>/dev/null || echo unknown)
  case "$uname_s" in
    Linux*)  os=linux ;;
    Darwin*) os=darwin ;;
    *) fail "unsupported OS: $uname_s (this installer is for Linux/macOS; use install.ps1 on Windows)" ;;
  esac
  case "$uname_m" in
    x86_64|amd64) arch=x86_64 ;;
    arm64|aarch64) arch=arm64 ;;
    *) fail "unsupported architecture: $uname_m" ;;
  esac
  echo "${os}-${arch}"
}

# ---------------------------------------------------------------------------
# Resolve the version: explicit -> latest stable release.
# ---------------------------------------------------------------------------
resolve_version() {
  if [ -n "${VERSION}" ]; then
    echo "$VERSION"
    return
  fi
  api="${GITHUB_URL}/repos/${REPO}/releases/latest"
  tag=$(curl -fsSL "$api" 2>/dev/null \
        | grep '"tag_name":' \
        | head -n1 \
        | sed -E 's/.*"tag_name": *"([^"]+)".*/\1/')
  [ -n "$tag" ] || fail "could not resolve latest release from $api"
  echo "$tag"
}

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || fail "missing required command: $1"
}

main() {
  require_cmd curl
  require_cmd tar

  platform=$(detect_platform)
  version=$(resolve_version)

  asset="${BINARY_NAME}-${platform}.tar.gz"
  download_url="https://github.com/${REPO}/releases/download/${version}/${asset}"
  sha_url="${download_url}.sha256"

  tmp=$(mktemp -d)
  trap 'rm -rf "$tmp"' EXIT

  log "Downloading ${asset} (${version})"
  curl -fsSL -o "${tmp}/${asset}" "$download_url" \
    || fail "failed to download $download_url"

  # Checksum verification.
  if curl -fsSL -o "${tmp}/${asset}.sha256" "$sha_url" 2>/dev/null; then
    log "Verifying sha256"
    cd "$tmp"
    if command -v sha256sum >/dev/null 2>&1; then
      sha256sum -c "${asset}.sha256" >/dev/null || fail "sha256 verification failed"
    elif command -v shasum >/dev/null 2>&1; then
      shasum -a 256 -c "${asset}.sha256" >/dev/null || fail "sha256 verification failed"
    else
      log "warning: no sha256 tool available; skipping checksum verification"
    fi
    cd - >/dev/null
  else
    log "warning: no sha256 sidecar at $sha_url; skipping checksum verification"
  fi

  log "Extracting"
  tar -xzf "${tmp}/${asset}" -C "$tmp"

  mkdir -p "$INSTALL_DIR"
  # The extracted top-level directory matches the asset stem.
  extracted_dir="${tmp}/${BINARY_NAME}-${platform}"
  [ -d "$extracted_dir" ] || extracted_dir="$tmp"

  # Move every executable file up into INSTALL_DIR. Adjust if your release
  # ships a fixed binary name.
  find "$extracted_dir" -maxdepth 2 -type f -perm -u+x -exec cp {} "$INSTALL_DIR/" \;

  chmod +x "${INSTALL_DIR}/${BINARY_NAME}" 2>/dev/null || true

  log ""
  log "Installed ${BINARY_NAME} ${version} to ${INSTALL_DIR}"
  case ":$PATH:" in
    *":${INSTALL_DIR}:"*) ;;
    *) log "Add ${INSTALL_DIR} to your PATH, e.g.:"
       log "  echo 'export PATH=\"${INSTALL_DIR}:\$PATH\"' >> ~/.bashrc" ;;
  esac
}

main "$@"
